{
  "name": "india-stock-fundamentals-scraper",
  "version": "1.0.0",
  "description": "Apify Actor for Indian stock fundamentals from Screener.in and Moneycontrol",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
